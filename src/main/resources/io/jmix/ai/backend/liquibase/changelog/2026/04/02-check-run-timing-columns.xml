<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2" author="merge">
        <addColumn tableName="CHECK_RUN">
            <column name="DURATION_MS" type="bigint"/>
            <column name="MODEL_RESPONSE_TOTAL_MS" type="bigint"/>
            <column name="FINISHED_AT" type="${offsetDateTime.type}"/>
        </addColumn>
        <addColumn tableName="CHECK_">
            <column name="MODEL_RESPONSE_TIME_MS" type="bigint"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
