<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="codex">
        <addColumn tableName="CHECK_RUN">
            <column name="DATASET_VERSION" type="varchar(255)"/>
            <column name="EVALUATOR_MODEL" type="varchar(255)"/>
            <column name="EVALUATOR_ENDPOINT" type="varchar(1000)"/>
            <column name="STATUS" type="varchar(50)"/>
            <column name="FAILURE_REASON" type="clob"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
