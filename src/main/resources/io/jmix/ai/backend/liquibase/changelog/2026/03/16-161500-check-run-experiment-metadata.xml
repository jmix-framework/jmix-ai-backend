<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="codex">
        <addColumn tableName="CHECK_DEF">
            <column name="GOLDEN" type="boolean"/>
        </addColumn>
        <addColumn tableName="CHECK_RUN">
            <column name="ANSWER_MODEL" type="varchar(255)"/>
            <column name="EXPERIMENT_KEY" type="varchar(255)"/>
            <column name="GOLDEN_ONLY" type="boolean"/>
            <column name="NOTES" type="clob"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
