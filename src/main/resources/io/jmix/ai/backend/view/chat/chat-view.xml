<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://chatView.title">
    <facets>
        <urlQueryParameters id="urlQueryParameters"/>
    </facets>
    <layout spacing="true" padding="false">
        <hbox width="100%" alignItems="CENTER" padding="true" spacing="true">
            <button id="newChatButton" text="New chat" themeNames="tertiary"/>
            <span text="Parameters:"/>
            <entityPicker id="parametersPicker" metaClass="Parameters" required="true" width="100%">
                <actions>
                    <action id="lookupAction" type="entity_lookup">
                        <properties>
                            <property name="viewId" value="Parameters.list"/>
                        </properties>
                    </action>
                    <action id="openAction" type="entity_open">
                        <properties>
                            <property name="viewId" value="Parameters.detail"/>
                        </properties>
                    </action>
                </actions>
            </entityPicker>
        </hbox>
    </layout>
</view>
