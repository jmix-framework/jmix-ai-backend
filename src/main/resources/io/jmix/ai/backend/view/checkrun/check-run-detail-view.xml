<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://checkRunDetailView.title"
      focusComponent="form">
    <data>
        <instance id="checkRunDc"
                  class="io.jmix.ai.backend.entity.CheckRun">
            <fetchPlan extends="_base"/>
            <loader id="checkRunDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <vbox id="form" width="100%" spacing="true">
            <formLayout id="runConfigForm" dataContainer="checkRunDc" width="100%">
                <responsiveSteps>
                    <responsiveStep minWidth="0" columns="1"/>
                    <responsiveStep minWidth="42em" columns="2"/>
                </responsiveSteps>
                <entityPicker id="parametersPicker" metaClass="Parameters" visible="false"
                              label="msg://io.jmix.ai.backend.entity/CheckRun.parameters" colspan="2">
                    <actions>
                        <action id="entityLookup" type="entity_lookup"/>
                        <action id="entityOpen" type="entity_open"/>
                        <action id="entityClear" type="entity_clear"/>
                    </actions>
                </entityPicker>
                <checkbox id="goldenOnlyField" property="goldenOnly"/>
                <textField id="experimentKeyField" property="experimentKey"/>
                <textArea id="notesField" minHeight="8em" property="notes" colspan="2"/>
            </formLayout>
            <vbox id="resultSection" width="100%" spacing="true">
                <formLayout id="summaryForm" dataContainer="checkRunDc" width="100%">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="42em" columns="2"/>
                    </responsiveSteps>
                    <comboBox id="statusField" property="status" readOnly="true"/>
                    <textField id="scoreField" property="score" readOnly="true"/>
                    <textField id="durationTextField" property="durationText" readOnly="true"/>
                    <textField id="modelResponseTotalTextField" property="modelResponseTotalText" readOnly="true"/>
                    <textField id="finishedAtField" property="finishedAt" readOnly="true"/>
                    <textField id="createdDateField" property="createdDate" readOnly="true"/>
                    <textField id="createdByField" property="createdBy" readOnly="true"/>
                    <textField id="answerModelField" property="answerModel" readOnly="true"/>
                    <textField id="datasetVersionField" property="datasetVersion" readOnly="true"/>
                </formLayout>
                <formLayout id="diagnosticsForm" dataContainer="checkRunDc" width="100%">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="42em" columns="2"/>
                    </responsiveSteps>
                    <textField id="retrievalProfileField" property="retrievalProfile" readOnly="true" colspan="2"/>
                    <textField id="promptRevisionField" property="promptRevision" readOnly="true"/>
                    <textField id="knowledgeSnapshotField" property="knowledgeSnapshot" readOnly="true"/>
                    <textField id="evaluatorModelField" property="evaluatorModel" readOnly="true"/>
                    <textField id="evaluatorEndpointField" property="evaluatorEndpoint" readOnly="true"/>
                    <textArea id="failureReasonField" minHeight="6em" property="failureReason" colspan="2" readOnly="true"/>
                    <textArea id="parametersField" minHeight="10em" property="parameters" colspan="2" readOnly="true"/>
                </formLayout>
            </vbox>
        </vbox>
        <hbox id="detailActions" visible="false">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
